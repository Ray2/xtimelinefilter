{
  "manifest_version": 3,
  "name": "Timeline Filter for X (Keyword Categories)",
  "version": "0.1.0",
  "description": "Hide tweets on X/Twitter based on category toggles using keyword/regex filters.",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "action": {
    "default_title": "Timeline Filter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}